plt.show()
print("Plot saved as training_curves.png")
 
def recommend_movies(genre, min_rating=7.5, top_n=5):
    genre = genre.strip().title()
    available = df['Genre'].unique().tolist()
    if genre not in available:
        print(f"Genre '{genre}' not found.\nAvailable: {sorted(available)}")
        return
 
    filtered = df[(df['Genre'] == genre) & (df['Rating'] >= min_rating)].copy()
    if filtered.empty:
        print(f"No {genre} movies with rating >= {min_rating}")
        return
 
    X_input = scaler.transform(filtered[['Rating', 'Votes', 'Year']])
    genre_enc = label_encoder.transform(filtered['Genre']).reshape(-1, 1)
    X_pred = np.hstack([genre_enc, X_input[:, 1:]])
    filtered['Model_Score'] = model.predict(X_pred, verbose=0).flatten()
 
    result = filtered.sort_values('Model_Score', ascending=False).head(top_n)
    print(f"\nTop {top_n} {genre} Recommendations:\n")
    for _, row in result.iterrows():
        print(f"  {row['Title']:<45} Rating: {row['Rating']}  ({int(row['Year'])})")
 
print("\nAvailable genres:", sorted(df['Genre'].unique()))
genre_input = input("\nEnter a genre: ")
recommend_movies(genre_input)
