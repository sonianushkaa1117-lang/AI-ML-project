    ],
    'Rating': [
        9.0, 8.8, 8.6, 8.7,
        8.4, 7.9, 9.2, 8.9,
        9.3, 8.8, 8.6,
        8.4, 8.3, 7.7, 8.1,
        7.3, 8.4, 8.0,
        8.0, 8.0, 7.9,
        7.3, 7.1, 7.5,
        7.9, 8.0,
