        8.4, 8.1
    ],
    'Votes': [
        2800000, 2300000, 1900000, 1900000,
        1200000, 1100000, 1800000, 2100000,
        2700000, 2000000, 750000,
        1100000, 650000, 700000, 950000,
        750000, 460000, 500000,
        800000, 590000, 680000,
        250000, 200000, 520000,
        430000, 310000,
        700000, 260000,
        390000, 350000
    ],
    'Year': [
        2008, 2010, 2014, 1999,
